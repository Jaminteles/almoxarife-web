# ──────────────────────────────────────────────
# Modelo de variáveis de ambiente do backend.
# Copie para .env e preencha com valores reais:
#   cp .env.example .env
# ──────────────────────────────────────────────

# Segurança do JWT
# Gere um segredo forte com:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Tempo de validade do token (ex.: 8h, 1d, 30m)
JWT_EXPIRES_IN=8h

# Custo do bcrypt para hash de senha
BCRYPT_ROUNDS=10

# Banco de dados (MySQL)
# Remoto (HostGator): dados em cPanel > "Bancos de Dados MySQL".
# DB_NAME/DB_USER costumam ter prefixo (ex.: cpaneluser_almox).
# DB_HOST = endereço do servidor da HostGator (não é localhost).
DB_NAME=bd_almoxarifado
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
